** Limpiamos cada servicio
./mvnw clean package -DskipTests



** Reinciamos docker por si acaso
docker compose down
docker compose up --build -d



** Verificación en Docker
docker exec microservices-pagos-service-1 sh -lc 'jar tf /app.jar | grep PaymentRetryPublisher'
ESPERADO = BOOT-INF/classes/com/example/pagos_service/messaging/PaymentRetryPublisher.class



** Provocamos fallo
docker compose stop mongodb



** Lanzamos pago
curl -i -X POST http://localhost:8080/pagos/procesar \
  -H 'Content-Type: application/json' \
  -d '{"ordenId":"ord-retry-002","monto":199.99,"estado":"pendiente"}'



** Revisamos logs del prodictor y del broker en Docker
docker compose logs --tail=200 pagos-service | grep -E "Publishing payment retry job|Payment retry message published"

docker compose logs --tail=200 broker-message-be | grep -E "Payment retry message consumed|Retry job failed|Retry job processed successfully"



** Revisamos Postgres en Docker, para validar que haya un error
docker exec broker-postgres psql -U broker -d broker_message -c "select id, job_type, status, data_status, send_email_status, update_retry_jobs_status, last_error, reference_id from retry_jobs order by id desc limit 10;"

docker exec broker-postgres psql -U broker -d broker_message -c "select id, retry_job_id, reference_id, orden_id, monto, pago_estado, execution_status, error_message from payments_retry_jobs order by id desc limit 10;"



** Levantamos Mongo
docker compose start mongodb
sleep 15



** Revisamos logs de nuevo en Docker
docker compose logs --tail=200 broker-message-be | grep -E "Payment retry message consumed|Retry job failed|Retry job processed successfully"

docker exec broker-postgres psql -U broker -d broker_message -c "select id, job_type, status, data_status, send_email_status, update_retry_jobs_status, last_error, reference_id from retry_jobs order by id desc limit 10;"